# ============================================
# AlphaReader - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# --- App ---
APP_ENV=development
DEBUG=true

# --- Logging ---
LOG_LEVEL=INFO            # DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_FORMAT=text           # "text" for human-readable, "json" for structured (log aggregation)

# --- Embedding Provider (去重用的向量化 API) ---
# 可选: "siliconflow"(硅基流动,免费) / "zhipu"(智谱AI,需购买额度)
EMBEDDING_PROVIDER=siliconflow

# --- SiliconFlow (硅基流动，仅用于 Embedding 去重) ---
# 注册: https://cloud.siliconflow.cn  免费模型: BAAI/bge-m3
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3

# --- Zhipu AI (智谱 Embedding，备选) ---
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_EMBEDDING_MODEL=embedding-3

# --- DeepSeek AI (评分 + 摘要统一驱动) ---
# 注册: https://platform.deepseek.com  默认 deepseek-v4-flash
# DEEPSEEK_API_KEY 同时驱动评分(LLM_API_KEY 复用)和摘要，配一个 key 即可
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-v4-flash

# --- LLM 评分/分析/公司名映射 (默认复用 DeepSeek，无需额外配置) ---
# LLM_API_KEY 默认读取 DEEPSEEK_API_KEY；如需评分与摘要用不同账号，再设 LLM_API_KEY
# LLM_API_URL=https://api.deepseek.com/v1/chat/completions
# LLM_MODEL=deepseek-v4-flash

# --- PostgreSQL ---
POSTGRES_USER=alphareader
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=alphareader
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- Dashboard ---
DASHBOARD_PASSWORD=your-dashboard-password-here

# --- Sandbox（模拟仓访问密码）---
SANDBOX_PASSWORD=your-sandbox-password-here

# --- Reports Sync Token ---
REPORT_SYNC_TOKEN=your-report-sync-token-here

# --- API Key (全局接口鉴权，为空则不启用) ---
NEWS_API_KEY=your-news-api-key-here

# --- AKShare Proxy (optional) ---
# Comma-separated list of HTTP proxies for akshare requests.
# Leave empty to disable proxy rotation.
# Example: AKSHARE_PROXIES=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
AKSHARE_PROXIES=
